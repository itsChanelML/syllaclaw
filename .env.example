# SyllaClaw — Environment Variables
# Copy this file: cp .env.example .env
# Fill in your values. Never commit .env to GitHub.

# REQUIRED — get free at build.nvidia.com (no credit card needed)
NIM_API_KEY=your_nim_api_key_here

# OPTIONAL — personalizes your output
STUDENT_NAME=Your Full Name
STUDENT_EMAIL=your@email.com